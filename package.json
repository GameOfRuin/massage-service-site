{
  "name": "massage-backend-api",
  "version": "1.0.0",
  "description": "Апи массажного бота",
  "main": "main.js",
  "author": "Massage AI",
  "license": "ISC",
  "scripts": {
    "prepare": "git config --local core.hooksPath .git-hooks/ || echo 'Not in a git repo'",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:debug": "cross-env APP_LOG_LEVEL=debug nest start --watch",
    "start:dev-ts-node": "ts-node-dev --respawn src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "docker:start": "cross-env COMPOSE_IGNORE_ORPHANS=true docker-compose -p platforma-services --file development/docker-compose.development.yml --project-name avtomat-backend up --detach",
    "docker:sh": "cross-env COMPOSE_IGNORE_ORPHANS=true docker-compose -p platforma-services --file development/docker-compose-shell.development.yml run --service-ports --rm --name avtomat-backend-api-sh avtomat-backend-api-sh sh",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "NODE_ENV=test jest --verbose",
    "test:watch": "npm test --watch",
    "test:cov": "npm test --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npm test --config ./test/jest-e2e.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "check-format": "prettier --check ./src",
    "check-types": "tsc --pretty --noEmit",
    "clean": "rm -rf node_modules/ && rm -rf dist/",
    "reset": "npm run clean && npm i",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli",
    "migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d=./src/infrastructure/database/typeorm.config.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d=./src/infrastructure/database/typeorm.config.ts",
    "migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate --pretty -d=./src/infrastructure/database/typeorm.config.ts ./src/migrations/$npm_config_name",
    "migration:create": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:create ./src/migrations/$npm_config_name",
    "migration:entity": "ts-node -r tsconfig-paths/register src/infrastructure/database/util/createEntity.ts",
    "migration:schema": "ts-node -r tsconfig-paths/register src/infrastructure/database/util/createCatalogSchema.ts",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d=./infrastructure/database/typeorm.config.js",
    "migration:revert:prod": "node ./node_modules/typeorm/cli.js migration:revert -d=./infrastructure/database/typeorm.config.js"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/request-context": "^6.2.0",
    "@fastify/static": "^8.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/platform-fastify": "^11.1.3",
    "@nestjs/schedule": "6.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@sentry/node": "^9.32.0",
    "@sentry/tracing": "^7.120.3",
    "amqplib": "^0.10.8",
    "bcrypt": "^6.0.0",
    "busboy": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cron-timezone-converter": "^1.0.0",
    "cron-validator": "^1.4.0",
    "cross-env": "^7.0.3",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.5.0",
    "exifr": "^7.1.3",
    "fluent-ffmpeg": "^2.1.3",
    "https-proxy-agent": "^7.0.6",
    "moment-timezone": "^0.6.0",
    "node-cron": "^4.2.1",
    "nodejs-snowflake": "^2.0.1",
    "nodemailer": "^7.0.3",
    "pg": "^8.16.2",
    "qs": "^6.14.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "typeorm": "^0.3.25"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/estree": "^1.0.9",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.4",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-sonarjs": "^1.0.4",
    "jest": "^30.0.3",
    "rimraf": "^6.0.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-watch": "^7.1.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint"
  }
}
