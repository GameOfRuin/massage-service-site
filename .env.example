NODE_ENV=development

APP_NAME=avtomat-backend-api
APP_LOG_LEVEL=info
APP_LOG_BLACKLIST=password,token,refreshToken,signature

APP_API_NAME="Massage Backend API"
APP_API_DESCRIPTION="Common endpoints"

APP_PORT=80
APP_HOST=0.0.0.0
APP_FRONTEND_URL=http://localhost:3000
#APP_ALLOW_CORS_ORIGIN_DOMAIN=127.0.0.1,127.0.0.2
APP_ALLOW_CORS_ORIGIN_DOMAIN=localhost

APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_USER=user
APP_DB_PASSWORD=pwd
APP_DB_NAME=db
APP_DB_SCHEMA=public
#опционально
#APP_DB_SSL=path/to/ca
